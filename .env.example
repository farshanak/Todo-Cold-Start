# ============================================================================
# Todo-Cold-Start — Environment Variables
# ============================================================================
# Run: cp .env.example .env
# NEVER commit .env to version control!
#
# These variables are consumed by backend/config.py (pydantic-settings).
# The frontend (vanilla TS, served as static files) does not read .env.

# ============================================================================
# REQUIRED - App will not start without these
# ============================================================================
# (none — this Todo app uses in-memory storage and has no external services.
#  When you swap to persistent storage, add DATABASE_URL here, then declare
#  it in backend/config.py as `database_url: str` with no default.)

# ============================================================================
# OPTIONAL - Defaults shown
# ============================================================================

# Uvicorn bind host/port for the FastAPI backend.
HOST=127.0.0.1
PORT=8000

# Comma-separated origins allowed by the backend CORS middleware.
# Include the dev static-server origin and any production frontends.
# Use * for "allow any origin" (development only — never in production).
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Log verbosity: critical | error | warning | info | debug | trace
LOG_LEVEL=info
